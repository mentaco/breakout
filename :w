#include <ncurses.h>
#include <thread>
#include "controller.h"

int Controller::q_input(int* ch) {
    *ch = getch();
    if (*ch == 'q') return 1;
    return 0;
}

void Controller::update() {
    // paddle.movement(ch);
    ball.movement();
}

void Controller::all_draw() {
    clear();
    paddle.draw();
    ball.draw();
    std::this_thread::sleep_for(std::chrono::milliseconds(15));
    refresh();
}

void Controller::all(int* loop) {
    while (*loop) {
        // this->update();
        this->all_draw();
    }
}

